{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "refresh": "30s",
  "tags": ["organism", "proxy", "claude"],
  "title": "Claude Code Memory",
  "uid": "claude-code-memory",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Anthropic API Cost",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(proxy_anthropic_cost_usd_total)",
          "legendFormat": "Total $",
          "refId": "A"
        }
      ],
      "title": "Total Cost ($)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 4, "w": 7, "x": 5, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(user_id)(increase(proxy_anthropic_cost_usd_total[24h]))",
          "legendFormat": "{{user_id}}",
          "refId": "A"
        }
      ],
      "title": "Cost by User ($ / 24h)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 4, "w": 7, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(model)(increase(proxy_anthropic_cost_usd_total[24h]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cost by Model ($ / 24h)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(proxy_requests_total)",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ],
      "title": "Total Proxy Requests",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Tokens",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(model)(rate(proxy_anthropic_input_tokens_total[5m])) * 60",
          "legendFormat": "input {{model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(model)(rate(proxy_anthropic_output_tokens_total[5m])) * 60",
          "legendFormat": "output {{model}}",
          "refId": "B"
        }
      ],
      "title": "Tokens per Minute (input / output)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(user_id)(rate(proxy_anthropic_input_tokens_total[5m])) * 60",
          "legendFormat": "input {{user_id}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(user_id)(rate(proxy_anthropic_output_tokens_total[5m])) * 60",
          "legendFormat": "output {{user_id}}",
          "refId": "B"
        }
      ],
      "title": "Tokens per Minute by User",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "title": "Memory (Organism)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 14 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(user_id)(rate(proxy_memory_injected_total[5m])) * 60",
          "legendFormat": "injected {{user_id}}",
          "refId": "A"
        }
      ],
      "title": "Memory-Injected Requests / min",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 14 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(proxy_memory_overhead_tokens_bucket[5m]))",
          "legendFormat": "p50 overhead tok",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(proxy_memory_overhead_tokens_bucket[5m]))",
          "legendFormat": "p95 overhead tok",
          "refId": "B"
        }
      ],
      "title": "Memory Overhead (tokens added by Organism)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 14 },
      "id": 23,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(proxy_memory_injected_total) / sum(proxy_requests_total) * 100",
          "legendFormat": "% with memory",
          "refId": "A"
        }
      ],
      "title": "Requests with Memory (%)",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 30,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "id": 31,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(proxy_forward_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(proxy_forward_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(proxy_forward_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Proxy Latency (p50 / p95 / p99 ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "id": 32,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(status)(rate(proxy_requests_total[5m])) * 60",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "title": "Requests / min (by status)",
      "type": "timeseries"
    }
  ]
}
