# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_HOME=/path/to/hf/cache           # where model weights are cached
# HF_TOKEN=hf_...                   # required for gated models (e.g. Llama 3.1)

# ── Organism ──────────────────────────────────────────────────────────────────
# ORGANISM_CONFIG_PATH=organism_config.yaml
# ORGANISM_MODEL_TYPE=qwen35        # overrides base_model.type in yaml
# ORGANISM_MODEL_NAME=Qwen/Qwen3.5-4B

# ── Python ────────────────────────────────────────────────────────────────────
TOKENIZERS_PARALLELISM=false
PYTHONUNBUFFERED=1

# ── Proxy mode (optional) ─────────────────────────────────────────────────────
# ORGANISM_ANTHROPIC_API_KEY=sk-ant-...   # your real Anthropic key (server-side only)
